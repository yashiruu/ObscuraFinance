@using Obscura.FinanceTracker.Domain.Enums

@code {
    [Parameter, EditorRequired]
    public TransactionType Type { get; set; }

    // Maps integer types to MudBlazor built-in theme colors
    private Color _chipColor => Type switch
    {
        TransactionType.Income => Color.Success, // Typically green
        TransactionType.Expense => Color.Error,   // Typically red
        _ => Color.Default
    };
}