@page "/categories/edit/{Id:guid}"

@using System.ComponentModel.DataAnnotations
@using Obscura.FinanceTracker.Application.Categories.Requests
@using Obscura.FinanceTracker.Client.Categories

@inject CategoryClient CategoryClient
@inject NavigationManager NavigationManager

<PageTitle>Edit Category — Obscura</PageTitle>

@* MudContainer centers the layout and controls maximum width *@
<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">

    @* MudToolBar acts as the page header *@
    <MudToolBar DisableGutters="true" Class="mb-4">
        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/categories" Color="Color.Default">
            Categories
        </MudButton>
        <MudSpacer />
        <MudText Typo="Typo.h5">Edit Category</MudText>
    </MudToolBar>

    @if (_isLoading)
    {
        @* MudProgressCircular shows a material design loading spinner *@
        <div class="d-flex justify-center my-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else if (_notFound)
    {
        @* MudAlert used to show a prominent not-found message *@
        <MudAlert Severity="Severity.Warning" Class="my-8">
            Category not found.
            <MudButton Variant="Variant.Text" Href="/categories" Class="ml-2">Back to Categories</MudButton>
        </MudAlert>
    }
    else
    {
        @* MudPaper wraps the form into a clean material card *@
        <MudPaper Class="pa-6" Elevation="3">
            <EditForm Model="@_model" OnValidSubmit="HandleSubmitAsync">
                <DataAnnotationsValidator />
                
                @* MudGrid handles the responsive 12-column layout *@
                <MudGrid>
                    <MudItem xs="12">
                        @* MudTextField replaces InputText. 'For' attribute automatically hooks into DataAnnotationsValidator *@
                        <MudTextField @bind-Value="_model.Name" Label="Name" For="@(() => _model.Name)" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_model.Description" Label="Description" Lines="3" For="@(() => _model.Description)" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12">
                        @* MudSelect replaces InputSelect for dropdowns *@
                        <MudSelect @bind-Value="_model.Type" Label="Type" For="@(() => _model.Type)" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="0">Income</MudSelectItem>
                            <MudSelectItem Value="1">Expense</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                </MudGrid>

                @if (_errorMessage is not null)
                {
                    <MudAlert Severity="Severity.Error" Class="mt-4">@_errorMessage</MudAlert>
                }

                @* Container for form action buttons *@
                <MudCardActions Class="mt-6 px-0">
                    <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="@_isSubmitting">Cancel</MudButton>
                    <MudSpacer />
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isSubmitting">
                        @(_isSubmitting ? "Saving…" : "Save Changes")
                    </MudButton>
                </MudCardActions>
            </EditForm>
        </MudPaper>
    }
</MudContainer>

@code {
    // ── Route parameter ──────────────────────────────────────────────
    [Parameter]
    public Guid Id { get; set; }

    // ── Local validation model ───────────────────────────────────────
    private sealed class EditCategoryFormModel
    {
        [Required(ErrorMessage = "Name is required.")]
        [StringLength(100, MinimumLength = 2, ErrorMessage = "Name must be between 2 and 100 characters.")]
        public string Name { get; set; } = string.Empty;

        [StringLength(500, ErrorMessage = "Description cannot exceed 500 characters.")]
        public string? Description { get; set; }

        [Range(0, 2, ErrorMessage = "Please select a valid type.")]
        public int Type { get; set; }
    }

    // ── State ────────────────────────────────────────────────────────
    private readonly EditCategoryFormModel _model = new();
    private bool _isLoading = true;
    private bool _notFound = false;
    private bool _isSubmitting = false;
    private string? _errorMessage;

    // ── Lifecycle ────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var category = await CategoryClient.GetByIdAsync(Id);

            if (category is null)
            {
                _notFound = true;
                return;
            }

            _model.Name = category.Name;
            _model.Description = category.Description;
            _model.Type = category.Type;
        }
        catch (Exception)
        {
            _notFound = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Handlers ─────────────────────────────────────────────────────
    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            var request = new UpdateCategoryRequest
            {
                Name = _model.Name.Trim(),
                Description = string.IsNullOrWhiteSpace(_model.Description)
                                  ? null
                                  : _model.Description.Trim(),
                Type = _model.Type,
                UpdateAt = DateTime.UtcNow,
                UpdateBy = null
            };

            await CategoryClient.UpdateAsync(Id, request);
            NavigationManager.NavigateTo("/categories");
        }
        catch (Exception)
        {
            _errorMessage = "Failed to save changes. Please check your connection and try again.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void Cancel()
        => NavigationManager.NavigateTo("/categories");
}