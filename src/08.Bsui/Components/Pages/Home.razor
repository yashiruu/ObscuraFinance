@page "/"

<PageTitle>Obscura Finance - Dashboard</PageTitle>

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
    @* 1. Welcome Section *@
    <MudText Typo="Typo.h3" Color="Color.Primary" Class="mb-2">
        <b>Hello, User!</b>
    </MudText>
    <MudText Typo="Typo.body1" Class="mb-8" Color="Color.Secondary">
        Welcome to Obscura Finance. Take control of your financial journey, track your expenses, and monitor your wealth securely.
    </MudText>

    @* 2. Dashboard Statistics (Mockup Data) *@
    <MudGrid Class="mb-8">
        @* Total Balance Card *@
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="2" Class="pa-6 d-flex flex-column align-center justify-center rounded-lg">
                <MudIcon Icon="@Icons.Material.Filled.AccountBalanceWallet" Color="Color.Primary" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Total Balance</MudText>
                <MudText Typo="Typo.h5" Class="mt-1"><b>Rp 15.000.000</b></MudText>
            </MudPaper>
        </MudItem>
    
        @* Monthly Income Card *@
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="2" Class="pa-6 d-flex flex-column align-center justify-center rounded-lg">
                <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Color="Color.Success" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Monthly Income</MudText>
                <MudText Typo="Typo.h5" Class="mt-1"><b>Rp 8.500.000</b></MudText>
            </MudPaper>
        </MudItem>
    
        @* Monthly Expenses Card *@
        <MudItem xs="12" sm="4">
            <MudPaper Elevation="2" Class="pa-6 d-flex flex-column align-center justify-center rounded-lg">
                <MudIcon Icon="@Icons.Material.Filled.TrendingDown" Color="Color.Error" Size="Size.Large" Class="mb-2" />
                <MudText Typo="Typo.subtitle2" Color="Color.Secondary">Monthly Expenses</MudText>
                <MudText Typo="Typo.h5" Class="mt-1"><b>Rp 3.200.000</b></MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* 3. Quick Actions Section *@
    <MudText Typo="Typo.h5" Class="mb-4"><b>Quick Actions</b></MudText>
    <MudGrid>
        @* Navigate to Categories *@
        <MudItem xs="12" sm="6" md="3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large"StartIcon="@Icons.Material.Filled.Category" Href="categories">
                Manage Category
            </MudButton>
        </MudItem>

        @* Navigate to Accounts *@
        <MudItem xs="12" sm="6" md="3">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large" StartIcon="@Icons.Material.Filled.Category" Href="accounts">
                Manage Account
            </MudButton>
        </MudItem>

        @* Placeholder for future feature *@
        <MudItem xs="12" sm="6" md="3">
            @* Inject our custom CSS class directly into the inner badge element using BadgeClass *@
            <MudBadge Content='"Coming Soon"' Color="Color.Warning" Overlap="true" Class="w-100" BadgeClass="custom-badge-position">
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" FullWidth="true" Size="Size.Large" Disabled="true" StartIcon="@Icons.Material.Filled.AddCard">
                    Add Transaction
                </MudButton>
            </MudBadge>
        </MudItem>
     </MudGrid>
</MudContainer>

<style>
    /* Target the badge element directly using a custom class */
    .custom-badge-position {
        inset: auto auto calc(100% - 5px) calc(100% - 96px) !important;
    }
</style>