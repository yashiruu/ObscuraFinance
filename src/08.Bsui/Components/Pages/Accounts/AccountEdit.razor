@page "/accounts/edit/{Id:guid}"

@using System.ComponentModel.DataAnnotations
@using Obscura.FinanceTracker.Application.Accounts.DTOs
@using Obscura.FinanceTracker.Application.DTOs.Accounts.Requests

@inject AccountClient AccountClient
@inject NavigationManager NavigationManager

<PageTitle>Edit Account — Obscura</PageTitle>

@* MudContainer centers the layout and controls maximum width *@
<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">

    @* MudToolBar acts as the page header *@
    <MudToolBar Class="mb-4">
        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/accounts" Color="Color.Default">
            Accounts
        </MudButton>
        <MudSpacer />
        <MudText Typo="Typo.h5">Edit Account</MudText>
    </MudToolBar>

    @if (_isLoading)
    {
        @* MudProgressCircular shows a material design loading spinner *@
        <div class="d-flex justify-center my-8">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else if (_notFound)
    {
        @* MudAlert for a prominent not-found message *@
        <MudAlert Severity="Severity.Warning" Class="my-8">
            Account not found.
            <MudButton Variant="Variant.Text" Href="/accounts" Class="ml-2">Back to Accounts</MudButton>
        </MudAlert>
    }
    else
    {
        @* MudPaper wraps the form into a clean material card *@
        <MudPaper Class="pa-6" Elevation="3">
            <EditForm Model="@_model" OnValidSubmit="HandleSubmitAsync">
                <DataAnnotationsValidator />

                @* MudGrid handles the responsive 12-column layout *@
                <MudGrid>
                    <MudItem xs="12">
                        @* MudTextField — 'For' attribute hooks into DataAnnotationsValidator *@
                        <MudTextField @bind-Value="_model.Name" Label="Name" For="@(() => _model.Name)"
                                      Required="true" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSelect @bind-Value="_model.Type" T="AccountType" Label="Type" For="@(() => _model.Type)" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                            @foreach (var type in Enum.GetValues<AccountType>())
                            {
                                <MudSelectItem Value="@type">
                                    @type
                                </MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_model.Description" Label="Description" Lines="3"
                                      For="@(() => _model.Description)"
                                      Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                </MudGrid>

                @if (_errorMessage is not null)
                {
                    <MudAlert Severity="Severity.Error" Class="mt-4">@_errorMessage</MudAlert>
                }

                @* Container for form action buttons *@
                <MudCardActions Class="mt-6 px-0">
                    <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="@_isSubmitting">Cancel</MudButton>
                    <MudSpacer />
                    <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isSubmitting">
                        @(_isSubmitting ? "Saving…" : "Save Changes")
                    </MudButton>
                </MudCardActions>
            </EditForm>
        </MudPaper>
    }
</MudContainer>

@code {
    // ── Route parameter ──────────────────────────────────────────────
    [Parameter]
    public Guid Id { get; set; }

    // ── Local validation model wrapping UpdateAccountRequest ─────────
    private sealed class EditAccountFormModel
    {
        [Required(ErrorMessage = "Name is required.")]
        [StringLength(100, MinimumLength = 2, ErrorMessage = "Name must be between 2 and 100 characters.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Account Type is required.")]
        public AccountType Type { get; set; }

        [StringLength(500, ErrorMessage = "Description cannot exceed 500 characters.")]
        public string? Description { get; set; }
    }

    // ── State ────────────────────────────────────────────────────────
    private readonly EditAccountFormModel _model = new();
    private bool _isLoading    = true;
    private bool _notFound     = false;
    private bool _isSubmitting = false;
    private string? _errorMessage;

    // ── Lifecycle ────────────────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        try
        {
            var account = await AccountClient.GetByIdAsync(Id);

            if (account is null)
            {
                _notFound = true;
                return;
            }

            // Pre-populate the form with the existing account data
            _model.Name        = account.Name;
            _model.Type        = account.Type;
            _model.Description = account.Description;
        }
        catch (Exception)
        {
            _notFound = true;
        }
        finally
        {
            _isLoading = false;
        }
    }

    // ── Handlers ─────────────────────────────────────────────────────
    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            var request = new UpdateAccountRequest
            {
                Name        = _model.Name.Trim(),
                Type        = _model.Type,
                Description = string.IsNullOrWhiteSpace(_model.Description)
                                  ? null
                                  : _model.Description.Trim(),
                UpdateAt = DateTime.UtcNow,
                UpdatedBy = Guid.Empty
            };

            await AccountClient.UpdateAsync(Id, request);
            NavigationManager.NavigateTo("/accounts");
        }
        catch (Exception ex)
        {
            _errorMessage = $"Failed to save changes. Please check your connection and try again. \nError Message: {ex}";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void Cancel()
        => NavigationManager.NavigateTo("/accounts");
}
