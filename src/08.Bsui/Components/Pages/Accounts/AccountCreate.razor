@page "/accounts/create"

@using System.ComponentModel.DataAnnotations

@inject AccountClient AccountClient
@inject NavigationManager NavigationManager

<PageTitle>New Account — Obscura</PageTitle>

@* MudContainer centers the content and restricts the maximum width *@
<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-6">

    @* MudToolBar acts as a header container *@
    <MudToolBar Class="mb-4">
        <MudButton StartIcon="@Icons.Material.Filled.ArrowBack" Href="/accounts" Color="Color.Default">
            Accounts
        </MudButton>
        <MudSpacer />
        <MudText Typo="Typo.h5">New Account</MudText>
    </MudToolBar>

    @* MudPaper creates a card-like surface with shadow *@
    <MudPaper Class="pa-6" Elevation="3">
        <EditForm Model="@_model" OnValidSubmit="HandleSubmitAsync">
            <DataAnnotationsValidator />

            @* MudGrid creates a responsive 12-column grid system *@
            <MudGrid>
                <MudItem xs="12">
                    @* MudTextField is the MudBlazor equivalent of InputText with built-in validation integration *@
                    <MudTextField @bind-Value="_model.Name" Label="Name" For="@(() => _model.Name)"
                                  Required="true" Placeholder="e.g. Main Wallet"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
                <MudItem xs="12">
                    @* MudSelect is the dropdown component substituting InputSelect *@
                    <MudSelect @bind-Value="_model.Type" T="AccountType" Label="Type" Required="true" Variant="Variant.Outlined" Margin="Margin.Dense">
                        @foreach (var type in Enum.GetValues<AccountType>())
                        {
                            <MudSelectItem Value="@type">
                                @type
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    @* MudNumericField is the typed numeric variant of MudTextField *@
                    <MudNumericField @bind-Value="_model.InitialBalance" Label="Initial Balance"
                                     For="@(() => _model.InitialBalance)" Min="0"
                                     Variant="Variant.Outlined" Margin="Margin.Dense"
                                     Adornment="Adornment.Start" AdornmentText="Rp" />
                </MudItem>
                <MudItem xs="12">
                    @* Lines="3" turns MudTextField into a textarea *@
                    <MudTextField @bind-Value="_model.Description" Label="Description" Lines="3"
                                  Placeholder="Optional description…" For="@(() => _model.Description)"
                                  Variant="Variant.Outlined" Margin="Margin.Dense" />
                </MudItem>
            </MudGrid>

            @if (_errorMessage is not null)
            {
                @* MudAlert replaces custom error banners *@
                <MudAlert Severity="Severity.Error" Class="mt-4">@_errorMessage</MudAlert>
            }

            @* Container for bottom buttons *@
            <MudCardActions Class="mt-6 px-0">
                <MudButton Variant="Variant.Text" OnClick="Cancel" Disabled="@_isSubmitting">Cancel</MudButton>
                <MudSpacer />
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Disabled="@_isSubmitting">
                    @(_isSubmitting ? "Saving…" : "Save Account")
                </MudButton>
            </MudCardActions>
        </EditForm>
    </MudPaper>
</MudContainer>

@code {
    // ── Local validation model wrapping CreateAccountRequest ─────────
    private sealed class CreateAccountFormModel
    {
        [Required(ErrorMessage = "Name is required.")]
        [StringLength(100, MinimumLength = 2, ErrorMessage = "Name must be between 2 and 100 characters.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Account Type is required.")]
        public AccountType Type { get; set; }

        [Range(0, double.MaxValue, ErrorMessage = "Initial balance must be zero or greater.")]
        public decimal InitialBalance { get; set; } = 0;

        [StringLength(500, ErrorMessage = "Description cannot exceed 500 characters.")]
        public string? Description { get; set; }
    }

    // ── State ────────────────────────────────────────────────────────
    private readonly CreateAccountFormModel _model = new();
    private bool _isSubmitting = false;
    private string? _errorMessage;

    // ── Handlers ─────────────────────────────────────────────────────
    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;

        try
        {
            var request = new CreateAccountRequest
            {
                Name           = _model.Name.Trim(),
                Type           = _model.Type,
                InitialBalance = _model.InitialBalance,
                Description    = string.IsNullOrWhiteSpace(_model.Description)
                                     ? null
                                     : _model.Description.Trim(),
                CreatedAt = DateTime.UtcNow,
                CreatedBy = Guid.Empty
            };

            await AccountClient.CreateAsync(request);
            NavigationManager.NavigateTo("/accounts");
        }
        catch (Exception)
        {
            _errorMessage = "Failed to save account. Please check your connection and try again.";
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void Cancel()
        => NavigationManager.NavigateTo("/accounts");
}
